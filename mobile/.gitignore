# Environment variables (contains API keys)
.env

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Firebase admin SDK (real keys never committed; the in-repo
# GoogleService-Info.plist + google-services.json are placeholders
# you replace with your own project's files).
firebase-service-account.json
*-firebase-adminsdk-*.json

# Apple signing keys / certs (never commit)
*.p8
*.p12
*.pem
*.cer

# Android signing keys
*.jks
*.keystore
android/key.properties
android/app/upload-keystore.jks

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Rust crate build artifacts (E2EE crypto FFI)
/rust/target/
