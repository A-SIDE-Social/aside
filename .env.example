# ── Core ──────────────────────────────────────────────────────
# Postgres credentials — used by both docker-compose and the API.
# DATABASE_URL is auto-constructed by docker-compose for the api service;
# set it here only for running outside Docker (e.g. local dev without containers).
POSTGRES_USER=aside
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aside
POSTGRES_PORT=5433
DATABASE_URL=postgres://aside:change-me@localhost:5433/aside
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
COOKIE_SECRET=change-me-cookie
PORT=3000
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
INVITE_LINK_HOST=http://localhost:3000
INVITE_LINK_ALLOWED_HOSTS=localhost
SUPPORT_EMAIL=support@example.com
LEGAL_TERMS_URL=http://localhost:3000/terms
LEGAL_PRIVACY_URL=http://localhost:3000/privacy
SYSTEM_USER_EMAIL=system@example.com

# ── Object Storage ───────────────────────────────────────────
# Works with AWS S3 and any S3-compatible provider (DO Spaces, MinIO, etc.)
S3_REGION=us-east-1
S3_BUCKET=aside-media

# For S3-compatible providers (leave empty for AWS S3):
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Explicit credentials (required for DO Spaces; optional for AWS if using IAM roles):
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# CDN URL for serving media (CloudFront, DO Spaces CDN, etc.):
# CDN_URL=https://media.example.com

# ── Email / Push / Subscriptions ─────────────────────────────
# Transactional OTP email. If POSTMARK_API_TOKEN is unset in dev/test,
# OTP delivery is logged/skipped and DEV_OTP can be used instead.
# POSTMARK_API_TOKEN=
OTP_FROM_EMAIL=noreply@example.com

# Firebase Admin service account path. Keep the JSON outside the repo.
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json

# Optional marketing broadcasts through Resend.
# RESEND_API_KEY=
MARKETING_FROM_EMAIL=broadcasts@example.com
MARKETING_REPLY_TO_EMAIL=support@example.com
UNSUBSCRIBE_BASE_URL=http://localhost:3000/unsubscribe
MARKETING_CTA_URL=http://localhost:3000

# Optional RevenueCat subscription integration.
# REVENUECAT_WEBHOOK_SECRET=
# REVENUECAT_API_KEY=

# Optional operator notifications.
# DISCORD_NEW_USER_WEBHOOK_URL=

# ── App Store / Play Store reviewer access ──────────────────
#
# DEV_OTP is an explicitly configured fixed OTP code that bypasses
# the real Postmark email round-trip. It can be used so App/Play
# Store reviewers can sign in without you being on standby to
# forward an email code.
#
# Scoping (enforced in src/routes/auth.ts):
#   - In dev/test NODE_ENV: applies to every email (matches
#     historical local-dev behavior).
#   - In production NODE_ENV: applies ONLY to emails listed in
#     DEV_OTP_ALLOWED_EMAILS. If the allowlist is empty in prod,
#     DEV_OTP is ignored entirely. Never globally on in prod —
#     that would be a full auth bypass dressed as testing
#     convenience.
#
# DEV_OTP=123456
# DEV_OTP_ALLOWED_EMAILS=reviewer@apple.com,reviewer@example.com
#
# Setting DEV_OTP also enables the auto-seed of the reusable
# `testinvite0000` invite code on startup (src/index.ts) so
# reviewers can complete the new-user flow without burning a
# real invite. The code resets to `pending` on every boot.

# ── Deployment Examples ──────────────────────────────────────
#
# AWS (Lightsail / ECS / EC2):
#   S3_REGION=us-east-1
#   S3_BUCKET=aside-media
#   CDN_URL=https://d1234.cloudfront.net
#
# DigitalOcean (App Platform / Droplet):
#   S3_REGION=nyc3
#   S3_BUCKET=aside-media
#   S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
#   S3_ACCESS_KEY=DO00XXXXXXXXXXXX
#   S3_SECRET_KEY=your-secret-key
#   CDN_URL=https://aside-media.nyc3.cdn.digitaloceanspaces.com
#
# Dev (no cloud storage needed — uses local filesystem):
#   Just set NODE_ENV=development, no S3 config required.
